<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Condition="'$(UseAvaloniaProGpu)' != 'true'">
    <PackageReference Include="Avalonia.Skia" />
  </ItemGroup>
  <ItemGroup Condition="'$(UseAvaloniaProGpu)' == 'true' and '$(TargetFramework)' == 'net10.0'">
    <ProjectReference Include="$(AvaloniaSourceRoot)\src\Skia\Avalonia.SkiaShim\Avalonia.SkiaShim.csproj" />
  </ItemGroup>
</Project>
